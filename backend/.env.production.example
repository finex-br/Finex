# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env.production and fill in your production values

# Environment
NODE_ENV=production
PORT=3000

# Database Configuration
# Replace with your Hostinger VPS database credentials
DATABASE_URL=postgresql://finex_user:CHANGE_THIS_PASSWORD@postgres:5432/finex_production

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=7d

# Redis Configuration (optional, for caching/sessions)
REDIS_URL=redis://redis:6379

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add your production URLs to authorized redirect URIs:
# - https://yourdomain.com/auth/google/callback
# - https://api.yourdomain.com/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/oauth/google/callback

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.com

# API Base URL
API_URL=https://api.yourdomain.com
