# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env.production and fill in your production values

# Backend API URL
# Replace with your actual domain
VITE_API_URL=https://api.yourdomain.com

# Google OAuth Configuration
# Get this from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Add your production URLs to authorized JavaScript origins and redirect URIs:
# Authorized JavaScript origins:
# - https://yourdomain.com
# Authorized redirect URIs:
# - https://yourdomain.com/auth/google/callback
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Application URL (used for OAuth callbacks)
VITE_APP_URL=https://yourdomain.com

# Sentry Error Tracking
# Get your DSN from: https://sentry.io/settings/projects/<project>/keys/
VITE_SENTRY_DSN=

# Sentry Source Maps Upload (build-time only, NOT prefixed with VITE_)
# These are used by the Vite build plugin and must be set in CI/CD
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=finex-frontend
# SENTRY_AUTH_TOKEN=sntrys_...
