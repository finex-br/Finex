# Backend API URL
VITE_API_URL=http://localhost:3000

# Google OAuth Configuration
# Para obter seu Google Client ID:
# 1. Acesse https://console.cloud.google.com/
# 2. Crie um novo projeto ou selecione um existente
# 3. Vá em "APIs & Services" > "Credentials"
# 4. Clique em "Create Credentials" > "OAuth client ID"
# 5. Selecione "Web application"
# 6. Adicione as URIs de redirecionamento autorizadas:
#    - http://localhost:5173/auth/google/callback (desenvolvimento)
#    - https://seu-dominio.com/auth/google/callback (produção)
# 7. Copie o Client ID gerado
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
